rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.lower() == 'edea.rangpur@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isFinanceOfficer() {
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.lower() == 'accounts@edea.com.bd' ||
        (exists(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())) &&
         get(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())).data.role == 'finance')
      );
    }

    function isSecretaryOfficer() {
      return isSignedIn() && request.auth.token.email != null && (
        exists(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())).data.role == 'secretary'
      );
    }

    function isValidECMember(data) {
      return data.keys().hasAll(['name', 'role', 'designation', 'institution', 'session', 'image', 'phone', 'userId', 'order', 'addedAt', 'addedBy']) &&
             data.name is string && data.role is string && data.userId is string;
    }

    // Membership Config
    match /config/membership {
      allow read: if true;
      allow write: if isAdmin() || isSignedIn();
    }

    // Association Config Rules
    match /config/association {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // Member ID Counter
    match /memberIds/counter {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.current == 1;
      allow update: if isSignedIn() && request.resource.data.current == resource.data.current + 1;
    }

    // Specialized Accounts
    match /specializedAccounts/{accountId} {
      allow get: if true; // Allow lookup for staff login check
      allow list: if isSignedIn(); // Allow specialized role lookup query
      allow write: if isAdmin();
    }

    // Finance Ledger
    match /finances/{financeId} {
      allow read: if true; // Allow dashboard visibility
      allow write: if isAdmin() || isFinanceOfficer() || true; // TEMPORARY for development/staff login
    }

    // Portal Config Rules
    match /config/portal {
      allow read: if true;
      allow write: if isAdmin() &&
        request.resource.data.keys().hasAll(['title', 'secretaryName', 'secretaryRole', 'secretaryInstitution', 'secretaryPhone', 'secretaryEmail', 'secretaryImage', 'ecCoverPhoto', 'description', 'updatedAt', 'updatedBy']) &&
        request.resource.data.keys().size() == 11 &&
        request.resource.data.title is string &&
        request.resource.data.updatedBy == request.auth.uid &&
        request.resource.data.updatedAt == request.time;
    }

    // Programs Rules
    match /programs/{programId} {
      allow read: if true;
      allow create: if isAdmin() &&
        request.resource.data.keys().hasAll(['title', 'category', 'date', 'location', 'description', 'image', 'status', 'createdAt', 'updatedAt']) &&
        request.resource.data.title is string && request.resource.data.title.size() <= 200 &&
        request.resource.data.description is string && request.resource.data.description.size() <= 5000;
      allow update: if isAdmin() &&
        request.resource.data.title is string && request.resource.data.title.size() <= 200;
      allow delete: if isAdmin();
    }

    // Notices Rules
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isAdmin() &&
        request.resource.data.keys().hasAll(['title', 'category', 'date', 'description', 'createdAt', 'updatedAt']) &&
        request.resource.data.title is string && request.resource.data.title.size() <= 200;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Users Rules (Association Members)
    match /users/{userId} {
      allow get: if true; 
      allow list: if true; // Allow member directory and dashboard queues
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId) || 
                   isAdmin() || 
                   isFinanceOfficer() || 
                   isSecretaryOfficer() ||
                   true; // TEMPORARY for development/staff login - In production, restrict to authenticated staff
    }

    // Executive Committee
    match /executiveCommittee/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fee Structures
    match /fees/{feeId} {
      allow read: if true; 
      allow write: if isAdmin() || isFinanceOfficer() || isSignedIn() || true; 
    }

    // Payment Submissions
    match /paymentSubmissions/{paymentId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || isFinanceOfficer() || true;
      allow delete: if isAdmin();
    }

    // Admins Rules
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System managed or via Firebase Console
    }
  }
}
