rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.lower() == 'edea.rangpur@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isFinanceOfficer() {
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.lower() == 'accounts@edea.com.bd' ||
        (exists(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())) &&
         get(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())).data.role == 'finance')
      );
    }

    function isSecretaryOfficer() {
      return isSignedIn() && request.auth.token.email != null && (
        exists(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email.lower())).data.role == 'secretary'
      );
    }

    function isValidECMember(data) {
      return data.keys().hasAll(['name', 'role', 'designation', 'institution', 'session', 'image', 'phone', 'userId', 'order', 'addedAt', 'addedBy']) &&
             data.name is string && data.role is string && data.userId is string;
    }

    // Membership Config
    match /config/membership {
      allow read: if true;
      allow write: if true;
    }

    // Association Config Rules
    match /config/association {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // Member ID Counter
    match /memberIds/counter {
      allow read, write: if true;
    }

    // Specialized Accounts
    match /specializedAccounts/{accountId} {
      allow get: if true; // Allow lookup for staff login check
      allow list: if true; // Relaxed for role lookup
      allow write: if isAdmin();
    }

    // Finance Ledger
    match /finances/{financeId} {
      allow read: if true; 
      allow write: if true; 
    }

    // Portal Config Rules
    match /config/portal {
      allow read: if true;
      allow write: if true;
    }

    // Programs Rules
    match /programs/{programId} {
      allow read: if true;
      allow write: if true;
    }

    // Notices Rules
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if true;
    }

    // Users Rules (Association Members)
    match /users/{userId} {
      allow read: if true; 
      allow write: if true; // Temporarily allow write for profile creation/updates
    }

    // Executive Committee
    match /executiveCommittee/{memberId} {
      allow read: if true;
      allow write: if true;
    }

    // Fee Structures
    match /fees/{feeId} {
      allow read: if true; 
      allow write: if true; 
    }

    // Payment Submissions
    match /paymentSubmissions/{paymentId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Admins Rules
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System managed or via Firebase Console
    }
  }
}
