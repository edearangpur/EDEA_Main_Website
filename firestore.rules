rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        request.auth.token.email == 'edea.rangpur@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isFinanceOfficer() {
      return isSignedIn() && isEmailVerified() && (
        exists(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/specializedAccounts/$(request.auth.token.email)).data.role == 'finance'
      );
    }

    // Association Config Rules
    match /config/association {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && 
        request.resource.data.keys().hasAll(['mission', 'vision', 'about', 'categories', 'heroImages', 'updatedAt', 'updatedBy']) &&
        request.resource.data.keys().size() == 7 &&
        request.resource.data.mission is string && request.resource.data.mission.size() <= 2000 &&
        request.resource.data.vision is string && request.resource.data.vision.size() <= 2000 &&
        request.resource.data.about is string && request.resource.data.about.size() <= 5000 &&
        request.resource.data.categories is list &&
        request.resource.data.heroImages is list &&
        request.resource.data.updatedBy == request.auth.uid &&
        request.resource.data.updatedAt == request.time;
    }

    // Specialized Accounts
    match /specializedAccounts/{accountId} {
      allow get: if true; // Allow lookup for staff login check
      allow list, write: if isAdmin();
    }

    // Finance Ledger
    match /finances/{financeId} {
      allow read, write: if isAdmin() || isFinanceOfficer();
    }

    // Portal Config Rules
    match /config/portal {
      allow read: if true;
      allow write: if isAdmin() &&
        request.resource.data.keys().hasAll(['title', 'secretaryName', 'secretaryRole', 'secretaryInstitution', 'secretaryPhone', 'secretaryEmail', 'secretaryImage', 'description', 'updatedAt', 'updatedBy']) &&
        request.resource.data.title is string &&
        request.resource.data.updatedBy == request.auth.uid &&
        request.resource.data.updatedAt == request.time;
    }

    // Programs Rules
    match /programs/{programId} {
      allow read: if true;
      allow create: if isAdmin() &&
        request.resource.data.keys().hasAll(['title', 'category', 'date', 'location', 'description', 'image', 'status', 'createdAt', 'updatedAt']) &&
        request.resource.data.title is string && request.resource.data.title.size() <= 200 &&
        request.resource.data.description is string && request.resource.data.description.size() <= 5000;
      allow update: if isAdmin() &&
        request.resource.data.title is string && request.resource.data.title.size() <= 200;
      allow delete: if isAdmin();
    }

    // Admins Rules
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System managed or via Firebase Console
    }
  }
}
