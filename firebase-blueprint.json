{
  "entities": {
    "associationConfig": {
      "title": "Association Configuration",
      "description": "Global settings for the association including mission and vision",
      "type": "object",
      "properties": {
        "mission": {
          "type": "string",
          "description": "The mission statement of the association"
        },
        "vision": {
          "type": "string",
          "description": "The vision statement of the association"
        },
        "about": {
          "type": "string",
          "description": "Information about the association"
        },
        "memberCountMode": {
          "type": "string",
          "enum": ["realtime", "manual"],
          "description": "How the member count is displayed on homepage"
        },
        "manualMemberCount": {
          "type": "number",
          "description": "The specific number of members to show if in manual mode"
        },
        "lastMemberSerial": {
          "type": "number",
          "description": "The last assigned sequential member ID number"
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Customizable list of program categories"
        },
        "heroImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of URLs for the homepage hero slider"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last updated timestamp"
        },
        "updatedBy": {
          "type": "string",
          "description": "UID of the admin who updated it"
        }
      },
      "required": ["mission", "vision", "about", "updatedAt", "updatedBy"]
    },
    "admin": {
      "title": "Admin User",
      "description": "Users with administrative privileges",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The email of the admin"
        },
        "role": {
          "type": "string",
          "enum": ["super_admin"],
          "description": "The role of the admin"
        }
      },
      "required": ["email", "role"]
    },
    "program": {
      "title": "Program",
      "description": "Association programs and events",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string", "description": "Short description for cards (bullet points allowed, 150 chars recommended)" },
        "details": { "type": "string", "description": "Extended details (HTML supported, bullet points allowed)" },
        "image": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "completed"] },
        "budget": {
          "type": "object",
          "properties": {
            "income": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "item": { "type": "string" },
                  "amount": { "type": "number" }
                }
              }
            },
            "expense": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "item": { "type": "string" },
                  "amount": { "type": "number" }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "date", "location", "description", "image", "status"]
    },
    "portalConfig": {
      "title": "Portal Configuration",
      "description": "Settings for the ICT Division & Portal section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "secretaryName": { "type": "string" },
        "secretaryRole": { "type": "string" },
        "secretaryInstitution": { "type": "string" },
        "secretaryPhone": { "type": "string" },
        "secretaryEmail": { "type": "string" },
        "secretaryImage": { "type": "string" },
        "ecCoverPhoto": { "type": "string", "description": "Cover photo for the Executive Committee section" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["title", "secretaryName", "secretaryRole", "secretaryInstitution", "secretaryPhone", "secretaryEmail", "secretaryImage", "description", "updatedAt", "updatedBy"]
    },
    "executiveMember": {
      "title": "Executive Committee Member",
      "description": "Members assigned to the Executive Committee",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "description": "The position title in the committee (e.g. President)" },
        "designation": { "type": "string", "description": "Professional job title" },
        "institution": { "type": "string" },
        "session": { "type": "string" },
        "image": { "type": "string" },
        "phone": { "type": "string" },
        "order": { "type": "number" },
        "addedAt": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["userId", "name", "role", "order"]
    },
    "specializedAccount": {
      "title": "Specialized Account",
      "description": "Accounts for specific administrative roles",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string", "description": "Access password for the account" },
        "role": { "type": "string", "enum": ["finance", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "password", "role"]
    },
    "financeEntry": {
      "title": "Finance Entry",
      "description": "Financial ledger transactions",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "recordedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "description", "date", "category", "recordedBy"]
    },
    "notice": {
      "title": "Notice",
      "description": "Official association announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["General", "Event", "Committee", "Financial"] },
        "fbLink": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "description", "category"]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "Association Member account profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["member_candidate", "member", "admin"] },
        "membershipStatus": { 
          "type": "string", 
          "enum": ["unpaid", "pending_finance", "declined_finance", "pending_secretary", "declined_secretary", "approved"],
          "description": "Current status in the membership approval workflow"
        },
        "transactionId": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["bkash", "nagad"] },
        "paymentAmount": { "type": "number" },
        "paymentSubmittedAt": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" },
        "session": { "type": "string", "description": "Academic or professional session" },
        "shift": { "type": "string", "description": "Work or study shift" },
        "bloodGroup": { "type": "string", "description": "Member's blood group" },
        "phone": { "type": "string", "description": "Optional contact number" },
        "companyName": { "type": "string", "description": "Current employer or company" },
        "profilePicture": { "type": "string", "description": "URL to the member's profile picture" },
        "memberCode": { "type": "string", "description": "Unique sequential membership ID (e.g., EDEA-1)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "isVerified"]
    },
    "memberIdCounter": {
      "title": "Member ID Counter",
      "description": "Stores the current sequential number for member IDs",
      "type": "object",
      "properties": {
        "current": { "type": "number", "description": "The current highest serial number assigned" }
      },
      "required": ["current"]
    },
    "membershipSettings": {
      "title": "Membership Settings",
      "description": "Configuration for membership payment and workflow",
      "type": "object",
      "properties": {
        "bkashNumber": { "type": "string" },
        "nagadNumber": { "type": "string" },
        "membershipAmount": { "type": "number" },
        "paymentInstructions": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "feeStructure": {
      "title": "Fee Structure",
      "description": "Recurring fees for executive members",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["yearly", "one-time"] },
        "frequency": { "type": "number" },
        "terms": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timeline": { "type": "string" },
              "lastDate": {
                "type": "object",
                "properties": {
                  "day": { "type": "number" },
                  "month": { "type": "number" }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      }
    },
    "paymentSubmission": {
      "title": "Payment Submission",
      "description": "Submissions for executive fee payments",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "feeId": { "type": "string" },
        "feeName": { "type": "string" },
        "termIndex": { "type": "number" },
        "year": { "type": "number" },
        "amount": { "type": "number" },
        "transactionDetails": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "config/membership": {
      "schema": "membershipSettings",
      "description": "Single document for membership payment settings"
    },
    "config/association": {
      "schema": "associationConfig",
      "description": "Single document for association mission and vision"
    },
    "memberIds/counter": {
      "schema": "memberIdCounter",
      "description": "Sequential counter for member IDs"
    },
    "config/portal": {
      "schema": "portalConfig",
      "description": "Single document for ICT portal settings"
    },
    "programs/{programId}": {
      "schema": "program",
      "description": "Collection of events and programs"
    },
    "admins/{adminId}": {
      "schema": "admin",
      "description": "Collection of admin users"
    },
    "specializedAccounts/{accountId}": {
      "schema": "specializedAccount",
      "description": "Collection of specialized accounts"
    },
    "finances/{financeId}": {
      "schema": "financeEntry",
      "description": "Financial ledger transactions"
    },
    "notices/{noticeId}": {
      "schema": "notice",
      "description": "Collection of official notices"
    },
    "fees/{feeId}": {
      "schema": "feeStructure",
      "description": "Collection of fee structures"
    },
    "paymentSubmissions/{paymentId}": {
      "schema": "paymentSubmission",
      "description": "Collection of fee payment submissions"
    },
    "users/{userId}": {
      "schema": "userProfile",
      "description": "Association Member profiles"
    },
    "executiveCommittee/{memberId}": {
      "schema": "executiveMember",
      "description": "Collection of members in the executive committee"
    }
  }
}
